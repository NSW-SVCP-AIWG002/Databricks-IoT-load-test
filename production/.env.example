# -------------------------------------------------------
# 環境変数テンプレート
# このファイルをコピーして .env を作成し、値を設定してください
# cp .env.example .env
# -------------------------------------------------------

# 負荷試験対象ホスト（Locust Web UI の Host 欄に表示される参考値）
TARGET_HOST=https://your-api.azurewebsites.net

# -------------------------------------------------------
# Azure IoT Hub 設定（必須）
# MqttDeviceUser および register_devices.py で使用する
# -------------------------------------------------------
IOTHUB_HOSTNAME=iot-nsw-iotbricks-dev.azure-devices.net

# デバイス認証情報 CSV パス（デフォルト: device_credentials.csv）
# register_devices.py で生成したファイルを指定する
# DEVICE_CREDENTIALS_FILE=device_credentials.csv

# -------------------------------------------------------
# Azure サービスプリンシパル認証（必須）
# register_devices.py の IoT Hub デバイス登録で使用する
# 必要ロール: IoT Hub Registry Contributor
# -------------------------------------------------------
AZURE_TENANT_ID=147132e0-2391-47db-9917-1fb023d41ad4
AZURE_CLIENT_ID=485cd5c0-0fb0-4a0c-b56b-0477e77690e2
AZURE_CLIENT_SECRET=5GI8Q~rxMpCFzp3JgjcNva2UV.-zRozQvpYiga3j

# -------------------------------------------------------
# Azure Event Hubs 設定（必須）
# EventHubConsumerUser のスループット確認で使用する
# -------------------------------------------------------
EVENTHUB_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=XXXX
EVENTHUB_NAME=eh-telemetry
# Event Hub のパーティション数（再作成した場合は実際の値に合わせること）
EVENTHUB_PARTITION_COUNT=16

# -------------------------------------------------------
# デバイススケール設定（docker-compose で上書きするため通常は不要）
# -------------------------------------------------------
# DEVICE_COUNT=200              # 送信デバイス台数
# DEVICE_ID_OFFSET=1            # デバイスID開始番号

# -------------------------------------------------------
# ADLS Gen2 設定（ADLSDeviceUser 使用時のみ必要）
# ADLSDeviceUser は現在コメントアウト中。使用再開時に設定すること。
# -------------------------------------------------------
# ADLS_STORAGE_ACCOUNT=your-storage-account
# ADLS_CONTAINER=bronze
# ADLS_PATH_PREFIX=telemetry/loadtest
